#!/bin/bash
# TBM commit-msg hook — enforces EMERGENCY: prefix when bypassing the freeze gate.
# Install once per clone: bash scripts/setup-hooks.sh
#
# When EMERGENCY=1 is set at commit time, the commit message MUST start with
# "EMERGENCY: <reason>" to guarantee an audit trail for every freeze bypass.
# Without this hook the bypass was print-only — no enforcement.
#
# Called by git with $1 = path to the file containing the commit message.

if [[ "${EMERGENCY:-0}" != "1" ]]; then
  exit 0
fi

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

if [[ "$COMMIT_MSG" != EMERGENCY:* ]]; then
  echo ""
  echo "❌ commit-msg: BLOCKED -- EMERGENCY=1 bypass requires the commit message"
  echo "   to start with 'EMERGENCY: <reason>' to create an audit trail."
  echo ""
  echo "   Got:      $COMMIT_MSG"
  echo "   Required: EMERGENCY: <your reason>"
  echo ""
  echo "   Re-run: EMERGENCY=1 git commit -m 'EMERGENCY: <reason>'"
  exit 1
fi

exit 0
