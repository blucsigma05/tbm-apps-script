#!/bin/bash
# TBM pre-push hook — re-runs deploy freeze gate before push.
# Install once per clone: bash scripts/setup-hooks.sh
#
# Adds a second enforcement layer on top of pre-commit: a commit made
# BEFORE a freeze was activated can still be blocked at push time.
#
# Override (genuine emergency only): EMERGENCY=1 git push
# The pushed commits must still carry EMERGENCY: prefix (commit-msg hook
# enforces this at commit time; pre-push reminds if the check was skipped).

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Skip in CI — the GAS smoke test is the authoritative check there.
if [[ "${CI:-}" == "true" ]]; then
  exit 0
fi

if [[ "${EMERGENCY:-0}" == "1" ]]; then
  echo "⚠️  pre-push: EMERGENCY=1 — freeze gate bypassed for push."
  echo "   Audit requirement: every pushed commit must start with 'EMERGENCY: <reason>'."
  exit 0
fi

if ! command -v jq >/dev/null 2>&1 || ! command -v clasp >/dev/null 2>&1; then
  echo "pre-push: WARN -- jq or clasp not available; freeze check skipped at push time."
  exit 0
fi

FREEZE_JSON=$(clasp run getFreezeState_ 2>/dev/null)
CLASP_EXIT=$?
if [[ $CLASP_EXIT -ne 0 || -z "$FREEZE_JSON" ]]; then
  echo "pre-push: BLOCKED -- clasp run getFreezeState_ failed (exit $CLASP_EXIT) or returned empty."
  echo "          Cannot confirm no active freeze — push rejected."
  echo "          To bypass (emergency only): EMERGENCY=1 git push"
  exit 1
fi

FREEZE_ACTIVE=$(echo "$FREEZE_JSON" | jq -r '.active // empty' 2>/dev/null)
JQ_EXIT=$?
if [[ $JQ_EXIT -ne 0 || -z "$FREEZE_ACTIVE" ]]; then
  echo "pre-push: BLOCKED -- cannot parse freeze state JSON."
  echo "          Raw: $FREEZE_JSON"
  echo "          To bypass (emergency only): EMERGENCY=1 git push"
  exit 1
fi

if [[ "$FREEZE_ACTIVE" == "true" ]]; then
  FREEZE_REASON=$(echo "$FREEZE_JSON" | jq -r '.reason // "unknown"' 2>/dev/null)
  FREEZE_EXPIRY=$(echo "$FREEZE_JSON" | jq -r '.expiresAt // "no expiry set"' 2>/dev/null)
  echo "pre-push: BLOCKED -- deploy freeze is ACTIVE"
  echo "  Reason:  $FREEZE_REASON"
  echo "  Expires: $FREEZE_EXPIRY"
  echo "  To bypass (emergency only): EMERGENCY=1 git push"
  echo "  Commit messages must start with: EMERGENCY: <reason>"
  exit 1
fi

exit 0
